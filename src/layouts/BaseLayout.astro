---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const APP_DESCRIPTION = 'A card-based habit app where your friends can make your challenges harder before you\'ve finished them. Five cards, two commitments, one ritual.';

const {
  title = 'CardHabit — A Habit Tracker Where Friends Make It Harder',
  description = APP_DESCRIPTION,
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://cardhabitapp.com');
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImage = new URL('/og-image-v2.png', siteUrl).href;

const sameAs = [
  'https://twitter.com/KessingerBuilds',
  'https://www.tiktok.com/@cardhabitapp',
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'MobileApplication',
  name: 'CardHabit',
  description: APP_DESCRIPTION,
  applicationCategory: 'LifestyleApplication',
  operatingSystem: 'iOS',
  url: siteUrl.href,
  image: ogImage,
  sameAs,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
    availability: 'https://schema.org/PreOrder',
    availabilityStarts: '2026-08-01',
  },
  publisher: {
    '@type': 'Organization',
    name: 'CardHabit',
    url: siteUrl.href,
    sameAs,
    founder: {
      '@type': 'Person',
      name: 'Brandon Kessinger',
      sameAs: ['https://twitter.com/KessingerBuilds'],
    },
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0c0c0e" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Search engine verification — replace tokens after registering -->
    <!-- <meta name="google-site-verification" content="REPLACE_WITH_GSC_TOKEN" /> -->
    <!-- <meta name="msvalidate.01" content="REPLACE_WITH_BING_TOKEN" /> -->

    <!-- OG -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="CardHabit — Show up. Every day." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="CardHabit" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="CardHabit — Show up. Every day." />
    <meta name="twitter:site" content="@KessingerBuilds" />
    <meta name="twitter:creator" content="@KessingerBuilds" />

    <!-- Favicon: 4-point gold star -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <!-- Fonts (non-blocking) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Jost:wght@300;400;500;600&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Jost:wght@300;400;500;600&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Jost:wght@300;400;500;600&display=swap"
      />
    </noscript>
  </head>
  <body>
    <slot />

    <!-- PostHog analytics (end of body, non-blocking) -->
    <script is:inline>
