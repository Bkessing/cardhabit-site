---
// Homepage internal-link mesh: contextual links to all 7 money pages
// with descriptive anchors, so none of them is footer-only.
const links = [
  { href: '/vs/75-hard', label: 'CardHabit vs 75 Hard' },
  { href: '/vs/habitica', label: 'CardHabit vs Habitica' },
  { href: '/vs/streaks', label: 'CardHabit vs Streaks' },
  { href: '/vs/finch', label: 'CardHabit vs Finch' },
  { href: '/vs/atoms', label: 'CardHabit vs Atoms' },
  { href: '/for/75-hard-quitters', label: 'If you quit 75 Hard' },
  { href: '/for/atomic-habits-readers', label: 'If you read Atomic Habits' },
];

const linkStyle = 'color:#c9a84c;text-decoration:none;border-bottom:0.5px solid rgba(201,168,76,0.4);';
---

<section id="compare" style="padding:5rem 0;">
  <div style="max-width:780px;margin:0 auto;padding:0 1.5rem;text-align:center;">
    <p class="fade-in" style="font-family:'Jost',system-ui,sans-serif;font-size:10px;font-weight:500;letter-spacing:0.28em;text-transform:uppercase;color:#c9a84c;margin:0 0 1.25rem;">
      Where you're coming from
    </p>
    <h2 class="fade-in" style="font-family:'Cormorant Garamond',Georgia,serif;font-weight:500;font-size:clamp(2rem,6vw,3rem);line-height:1.08;letter-spacing:-0.01em;color:#f0ebe0;margin:0 0 1.5rem;">
      You've tried <em style="color:#c9a84c;font-style:italic;">something.</em>
    </h2>
    <p class="fade-in" style="font-family:'Jost',system-ui,sans-serif;font-weight:300;font-size:1rem;line-height:1.7;color:#a39e92;max-width:560px;margin:0 auto 2rem;">
      You're probably not starting from zero. Whether you burned out on a 75-day program, kept a checkbox app alive without changing anything, or read the book and stalled at the last page, there's a page here for the road you took.
    </p>
    <p class="fade-in" style="font-family:'Cormorant Garamond',Georgia,serif;font-style:italic;font-size:1.25rem;line-height:1.9;color:#a39e92;margin:0;">
      {links.map((l, i) => (
        <>
          {i > 0 && <span> &nbsp;·&nbsp; </span>}
          <a href={l.href} style={linkStyle}>{l.label}</a>
        </>
      ))}
    </p>
  </div>
</section>
