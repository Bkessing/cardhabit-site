---

const steps = [
  {
    numeral: 'I',
    title: 'Draw',
    body: 'Five cards at dawn. One per category — Physical, Mental, Nutrition, Recovery, Wildcard. Calibrated to your archetype and tier.',
  },
  {
    numeral: 'II',
    title: 'Commit',
    body: 'Pick your hand. The ones you choose are yours alone — locked in, untouchable by anyone, including your friends.',
  },
  {
    numeral: 'III',
    title: 'Complete',
    body: 'Hold for a second and a half. The card is done. A vault card drops. The harder the challenge, the better the play you earn.',
  },
  {
    numeral: 'IV',
    title: 'Tomorrow',
    body: 'Your friends have been raising the bar. Whatever lands in front of you, you do it anyway. That\'s the practice.',
  },
];
---

<section style="padding:5rem 0;">
  <div style="max-width:780px;margin:0 auto;padding:0 1.5rem;">

    <!-- Eyebrow -->
    <p class="fade-in" style="font-family:'Jost',system-ui,sans-serif;font-size:10px;font-weight:500;letter-spacing:0.28em;text-transform:uppercase;color:#c9a84c;margin:0 0 1.25rem;text-align:center;">
      The ritual
    </p>

    <!-- H2 -->
    <h2 class="fade-in" style="font-family:'Cormorant Garamond',Georgia,serif;font-weight:500;font-size:clamp(2rem,6vw,3rem);line-height:1.08;letter-spacing:-0.01em;color:#f0ebe0;margin:0 0 3rem;text-align:center;">
      The daily <em style="color:#c9a84c;font-style:italic;">ritual.</em>
    </h2>

    <!-- Steps -->
    <div style="max-width:620px;margin:0 auto;">
      {steps.map((step, i) => (
        <div
          class="fade-in"
          style={`display:flex;gap:2rem;align-items:flex-start;padding:2rem 0;${i > 0 ? 'border-top:0.5px solid rgba(201,168,76,0.18);' : ''}`}
        >
          <!-- Roman numeral -->
          <div style="min-width:50px;font-family:'Cormorant Garamond',Georgia,serif;font-style:italic;font-size:2.25rem;line-height:1;color:#c9a84c;padding-top:2px;">
            {step.numeral}
          </div>

          <!-- Content -->
          <div>
            <h3 style="font-family:'Cormorant Garamond',Georgia,serif;font-weight:500;font-size:1.5rem;color:#f0ebe0;margin:0 0 0.5rem;">
              {step.title}
            </h3>
            <p style="font-family:'Jost',system-ui,sans-serif;font-weight:300;font-size:0.98rem;line-height:1.7;color:#a39e92;margin:0;">
              {step.body}
            </p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
