    <a href="/for/atomic-habits-readers" class="footer-link" style="font-family:'Jost',system-ui,sans-serif;font-size:11px;font-weight:400;color:#6b6760;text-decoration:none;transition:color 0.2s;">For Atomic Habits readers</a>
  </div>

  <!-- Secondary links -->
  <div style="display:flex;align-items:center;justify-content:center;flex-wrap:wrap;gap:1.5rem;margin-bottom:1.5rem;">
    <a href="mailto:hello@cardhabitapp.com" class="footer-link" style="font-family:'Jost',system-ui,sans-serif;font-size:12px;font-weight:400;color:#6b6760;text-decoration:none;transition:color 0.2s;">Contact</a>
