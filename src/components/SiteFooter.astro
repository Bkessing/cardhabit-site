<footer style="padding:3rem 1.5rem;text-align:center;">
  <!-- 4-point gold star (large) -->
  <div style="margin-bottom:1rem;">
    <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M16,2 L17.4,13.6 L28,16 L17.4,18.4 L16,30 L14.6,18.4 L4,16 L14.6,13.6 Z" fill="#c9a84c"/>
    </svg>
