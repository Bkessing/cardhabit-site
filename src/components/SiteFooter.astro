<style>
  .footer-link:hover {
    color: #c9a84c;
  }
  /* Badge sits quietly in the dark footer until hovered */
  .nl-badge {
    display: inline-block;
    opacity: 0.55;
    filter: grayscale(40%);
    transition: opacity 0.2s, filter 0.2s;
  }
  .nl-badge:hover {
    opacity: 1;
    filter: none;
  }
</style>
