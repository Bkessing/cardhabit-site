  <div style="display:flex;align-items:center;justify-content:center;flex-wrap:wrap;gap:1.25rem;margin-bottom:0.75rem;">
    <a href="/vs/75-hard" class="footer-link" style="font-family:'Jost',system-ui,sans-serif;font-size:11px;font-weight:400;color:#6b6760;text-decoration:none;transition:color 0.2s;">vs 75 Hard</a>
    <a href="/vs/habitica" class="footer-link" style="font-family:'Jost',system-ui,sans-serif;font-size:11px;font-weight:400;color:#6b6760;text-decoration:none;transition:color 0.2s;">vs Habitica</a>
    <a href="/vs/streaks" class="footer-link" style="font-family:'Jost',system-ui,sans-serif;font-size:11px;font-weight:400;color:#6b6760;text-decoration:none;transition:color 0.2s;">vs Streaks</a>
