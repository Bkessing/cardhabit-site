---
---

<section
  style="position:relative;overflow:hidden;text-align:center;padding:4.5rem 1.5rem 5rem;min-height:calc(100vh - 56px);display:flex;align-items:center;justify-content:center;"
>
  <!-- Hero content -->
  <div style="position:relative;z-index:2;max-width:700px;width:100%;">
    <!-- Eyebrow -->
    <div class="fade-in" style="display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:2.5rem;">
      <span style="font-family:'Jost',system-ui,sans-serif;font-size:10px;font-weight:500;letter-spacing:0.28em;text-transform:uppercase;color:#c9a84c;">CardHabit</span>
      <div style="width:6px;height:6px;border-radius:50%;background:#c9a84c;"></div>
      <span style="font-family:'Jost',system-ui,sans-serif;font-size:10px;font-weight:500;letter-spacing:0.28em;text-transform:uppercase;color:#c9a84c;">Coming August 2026</span>
      <div style="width:6px;height:6px;border-radius:50%;background:#c9a84c;"></div>
      <span style="font-family:'Jost',system-ui,sans-serif;font-size:10px;font-weight:500;letter-spacing:0.28em;text-transform:uppercase;color:#c9a84c;">iOS</span>
    </div>

    <!-- H1 -->
    <h1
      class="fade-in"
      style="font-family:'Cormorant Garamond',Georgia,serif;font-weight:500;font-size:clamp(2.4rem,9vw,4.5rem);line-height:1.02;letter-spacing:-0.015em;color:#f0ebe0;margin:0 0 1.75rem;"
    >
      Show up. <em style="color:#c9a84c;font-style:italic;">Every day.</em>
    </h1>

    <!-- Subhead -->
    <p
      class="fade-in"
      style="font-family:'Jost',system-ui,sans-serif;font-weight:300;font-size:1.05rem;line-height:1.65;color:#a39e92;max-width:560px;margin:0 auto 2.5rem;"
    >
      A card-based habit app where your friends can make your challenges harder before you've finished them. Five cards a day. Commit to your day. Hold to lock them in. Become someone.
    </p>

    <!-- CTA -->
    <div class="fade-in">
      <a
        href="#waitlist"
        class="hero-cta"
        style="display:inline-block;background:#c9a84c;color:#0c0c0e;font-family:'Jost',system-ui,sans-serif;font-weight:500;font-size:13px;letter-spacing:0.12em;text-transform:uppercase;padding:1rem 2.25rem;border-radius:3px;text-decoration:none;transition:background 0.2s,transform 0.2s;border:1px solid #c9a84c;"
      >
        Join the waitlist
      </a>
    </div>

    <!-- Below CTA note -->
    <p
      class="fade-in"
      style="font-family:'Jost',system-ui,sans-serif;font-size:10px;font-weight:400;letter-spacing:0.1em;text-transform:uppercase;color:#6b6760;margin-top:1.25rem;"
    >
      Free during beta &nbsp;·&nbsp; Founder pricing for early signups
    </p>
  </div>
</section>

<style>
  .hero-cta:hover {
    background: #d9b86b;
    transform: translateY(-1px);
  }
</style>
