---
---

<section
  style="position:relative;overflow:hidden;text-align:center;padding:4.5rem 1.5rem 5rem;min-height:calc(100vh - 56px);display:flex;align-items:center;justify-content:center;"
>
  <!-- Fanned card deck silhouette (decorative, behind hero text) -->
  <div
    class="card-deck"
    aria-hidden="true"
    style="position:absolute;inset:0;z-index:0;pointer-events:none;display:flex;align-items:center;justify-content:center;"
  >
    <div style="position:relative;width:420px;height:320px;">
      <!-- Card 1 (far left) -->
      <div style="position:absolute;left:0;top:50%;transform:translateY(-50%) rotate(-14deg);transform-origin:center bottom;width:80px;height:112px;border:1px solid rgba(201,168,76,0.35);border-radius:6px;background:#0c0c0e;display:flex;align-items:center;justify-content:center;">
        <svg width="10" height="10" viewBox="0 0 32 32" fill="none"><path d="M16,2 L17.4,13.6 L28,16 L17.4,18.4 L16,30 L14.6,18.4 L4,16 L14.6,13.6 Z" fill="rgba(201,168,76,0.4)"/></svg>
      </div>
      <!-- Card 2 (left) -->
      <div style="position:absolute;left:70px;top:50%;transform:translateY(-50%) rotate(-7deg);transform-origin:center bottom;width:80px;height:112px;border:1px solid rgba(201,168,76,0.35);border-radius:6px;background:#0c0c0e;display:flex;align-items:center;justify-content:center;">
        <svg width="10" height="10" viewBox="0 0 32 32" fill="none"><path d="M16,2 L17.4,13.6 L28,16 L17.4,18.4 L16,30 L14.6,18.4 L4,16 L14.6,13.6 Z" fill="rgba(201,168,76,0.4)"/></svg>
      </div>
      <!-- Card 3 (center, slightly larger and forward) -->
      <div style="position:absolute;left:50%;top:50%;transform:translate(-50%,-52%);width:90px;height:126px;border:1px solid rgba(201,168,76,0.45);border-radius:6px;background:#0f0f12;display:flex;align-items:center;justify-content:center;box-shadow:0 0 32px rgba(201,168,76,0.06);">
        <svg width="12" height="12" viewBox="0 0 32 32" fill="none"><path d="M16,2 L17.4,13.6 L28,16 L17.4,18.4 L16,30 L14.6,18.4 L4,16 L14.6,13.6 Z" fill="rgba(201,168,76,0.5)"/></svg>
      </div>
      <!-- Card 4 (right) -->
      <div style="position:absolute;right:70px;top:50%;transform:translateY(-50%) rotate(7deg);transform-origin:center bottom;width:80px;height:112px;border:1px solid rgba(201,168,76,0.35);border-radius:6px;background:#0c0c0e;display:flex;align-items:center;justify-content:center;">
        <svg width="10" height="10" viewBox="0 0 32 32" fill="none"><path d="M16,2 L17.4,13.6 L28,16 L17.4,18.4 L16,30 L14.6,18.4 L4,16 L14.6,13.6 Z" fill="rgba(201,168,76,0.4)"/></svg>
      </div>
      <!-- Card 5 (far right) -->
      <div style="position:absolute;right:0;top:50%;transform:translateY(-50%) rotate(14deg);transform-origin:center bottom;width:80px;height:112px;border:1px solid rgba(201,168,76,0.35);border-radius:6px;background:#0c0c0e;display:flex;align-items:center;justify-content:center;">
        <svg width="10" height="10" viewBox="0 0 32 32" fill="none"><path d="M16,2 L17.4,13.6 L28,16 L17.4,18.4 L16,30 L14.6,18.4 L4,16 L14.6,13.6 Z" fill="rgba(201,168,76,0.4)"/></svg>
      </div>
    </div>
  </div>

  <!-- Hero content -->
  <div style="position:relative;z-index:2;max-width:700px;margin:0 auto;">
    <!-- Eyebrow -->
    <div class="fade-in" style="display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:2.5rem;">
      <span style="font-family:'Jost',system-ui,sans-serif;font-size:10px;font-weight:500;letter-spacing:0.28em;text-transform:uppercase;color:#c9a84c;">CardHabit</span>
      <div style="width:6px;height:6px;border-radius:50%;background:#c9a84c;"></div>
      <span style="font-family:'Jost',system-ui,sans-serif;font-size:10px;font-weight:500;letter-spacing:0.28em;text-transform:uppercase;color:#c9a84c;">Coming August 2026</span>
      <div style="width:6px;height:6px;border-radius:50%;background:#c9a84c;"></div>
      <span style="font-family:'Jost',system-ui,sans-serif;font-size:10px;font-weight:500;letter-spacing:0.28em;text-transform:uppercase;color:#c9a84c;">iOS</span>
    </div>

    <!-- H1 -->
    <h1
      class="fade-in"
      style="font-family:'Cormorant Garamond',Georgia,serif;font-weight:500;font-size:clamp(2.4rem,9vw,4.5rem);line-height:1.02;letter-spacing:-0.015em;color:#f0ebe0;margin:0 0 1.75rem;"
    >
      Show up. <em style="color:#c9a84c;font-style:italic;">Every day.</em>
    </h1>

    <!-- Subhead -->
    <p
      class="fade-in"
      style="font-family:'Jost',system-ui,sans-serif;font-weight:300;font-size:1.05rem;line-height:1.65;color:#a39e92;max-width:560px;margin:0 auto 2.5rem;"
    >
      A card-based habit app where your friends can make your challenges harder before you've finished them. Five cards a day. Commit to two or three. Hold to lock them in. Become someone.
    </p>

    <!-- CTA -->
    <div class="fade-in">
      <a
        href="#waitlist"
        class="hero-cta"
        style="display:inline-block;background:#c9a84c;color:#0c0c0e;font-family:'Jost',system-ui,sans-serif;font-weight:500;font-size:13px;letter-spacing:0.12em;text-transform:uppercase;padding:1rem 2.25rem;border-radius:3px;text-decoration:none;transition:background 0.2s,transform 0.2s;border:1px solid #c9a84c;"
      >
        Join the waitlist
      </a>
    </div>

    <!-- Below CTA note -->
    <p
      class="fade-in"
      style="font-family:'Jost',system-ui,sans-serif;font-size:10px;font-weight:400;letter-spacing:0.1em;text-transform:uppercase;color:#6b6760;margin-top:1.25rem;"
    >
      Free during beta &nbsp;·&nbsp; Founder pricing for early signups
    </p>
  </div>
</section>

<style>
  .hero-cta:hover {
    background: #d9b86b;
    transform: translateY(-1px);
  }
</style>
