---
// BreadcrumbList JSON-LD for /vs/* and /for/* pages: Home -> section -> page.
// Schema only; no visible markup (the design has no breadcrumb bar).
// The middle crumb resolves to the homepage "Where you're coming from" section.
interface Props {
  section: string;
  name: string;
}

const { section, name } = Astro.props;
const site = 'https://cardhabitapp.com';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${site}/` },
    { '@type': 'ListItem', position: 2, name: section, item: `${site}/#compare` },
    { '@type': 'ListItem', position: 3, name },
  ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
