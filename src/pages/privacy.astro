---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import SiteFooter from '../components/SiteFooter.astro';

const lastUpdated = 'June 5, 2026';
---

<BaseLayout
  title="Privacy Policy — CardHabit"
  description="How CardHabit collects, uses, and protects your information."
>
  <Nav />
  <main class="policy-main">
    <article class="policy-article">
      <p class="policy-eyebrow">Privacy</p>
      <h1 class="policy-h1">Privacy Policy</h1>
      <p class="policy-updated">Last updated: {lastUpdated}</p>

      <section class="policy-section">
        <p>
          CardHabit ("we", "us", "our") operates the CardHabit iOS application and cardhabitapp.com. This policy explains what data we collect, why, and how you can control it.
        </p>
      </section>

      <section class="policy-section">
        <h2>Information we collect</h2>
        <ul>
          <li><strong>Account data.</strong> Your email address and display name when you sign up to the app, or your email address when you join the waitlist.</li>
          <li><strong>Usage data.</strong> Which cards you draw, commit to, and complete; streak counts; archetype progression; social actions you send or receive.</li>
          <li><strong>Device data.</strong> APNs device token for push notifications; device type and OS version for crash reporting; anonymized device identifiers for product analytics.</li>
          <li><strong>Purchase data.</strong> Subscription tier (Pro or Elite) and renewal status. We do not store payment card information — all payments are handled by Apple.</li>
          <li><strong>Social data.</strong> Friend connections you initiate and the sabotage and buff actions you send or receive.</li>
          <li><strong>Diagnostic data.</strong> Crash reports, error logs, and performance metrics.</li>
        </ul>
      </section>

      <section class="policy-section">
        <h2>How we use your information</h2>
        <ul>
          <li>Deliver and personalize the app experience (daily card draws, archetype assignment, streak tracking, social mechanics).</li>
          <li>Send push notifications about your daily ritual, streak alerts, and social actions from friends.</li>
          <li>Understand how the app is used so we can improve it.</li>
          <li>Diagnose crashes and errors so we can fix them.</li>
          <li>Manage subscriptions and entitlements.</li>
        </ul>
      </section>

      <section class="policy-section">
        <h2>Third-party services</h2>
        <p>
          CardHabit uses the following service providers. Each has its own privacy policy linked below.
        </p>
        <ul>
          <li><strong>Supabase</strong> — database, authentication, and realtime infrastructure. <a href="https://supabase.com/privacy" target="_blank" rel="noopener">supabase.com/privacy</a></li>
          <li><strong>PostHog</strong> — product analytics. <a href="https://posthog.com/privacy" target="_blank" rel="noopener">posthog.com/privacy</a></li>
          <li><strong>RevenueCat</strong> — subscription management. <a href="https://www.revenuecat.com/privacy" target="_blank" rel="noopener">revenuecat.com/privacy</a></li>
          <li><strong>Sentry</strong> — crash and error reporting. <a href="https://sentry.io/privacy/" target="_blank" rel="noopener">sentry.io/privacy</a></li>
          <li><strong>Apple (APNs)</strong> — push notification delivery and payment processing. <a href="https://www.apple.com/legal/privacy/" target="_blank" rel="noopener">apple.com/legal/privacy</a></li>
        </ul>
        <p>
          We share information only with these providers as required to operate the app. We do not sell your personal information to anyone.
        </p>
      </section>

      <section class="policy-section">
        <h2>Data retention</h2>
        <p>
          We retain your account data for as long as your account is active. When you delete your account, all of your data — cards, streaks, commitments, social history, friend connections — is permanently deleted within 24 hours. Waitlist emails are retained until you unsubscribe or request deletion.
        </p>
      </section>

      <section class="policy-section">
        <h2>Deleting your account</h2>
        <p>
          You can permanently delete your account and all associated data from inside the app at <strong>Profile → Delete Account</strong>. This action is irreversible. Your subscription, if any, must be cancelled separately through the iOS App Store.
        </p>
      </section>

      <section class="policy-section">
        <h2>Your choices</h2>
        <p>
          You can request access to or deletion of your data at any time by emailing <a href="mailto:brandkessinger@gmail.com">brandkessinger@gmail.com</a>. You can unsubscribe from waitlist emails using the link in any message we send you.
        </p>
      </section>

      <section class="policy-section">
        <h2>Children</h2>
        <p>
          CardHabit is not directed at children under 13. We do not knowingly collect personal information from children under 13. If you believe a child has provided us with personal data, contact us and we will delete it.
        </p>
      </section>

      <section class="policy-section">
        <h2>Changes to this policy</h2>
        <p>
          We may update this policy as the product evolves. We will update the "Last updated" date above and, for material changes, notify you inside the app. Continued use after changes take effect constitutes acceptance.
        </p>
      </section>

      <section class="policy-section">
        <h2>Contact</h2>
        <p>
          Questions about this policy or requests regarding your data: <a href="mailto:brandkessinger@gmail.com">brandkessinger@gmail.com</a>.
        </p>
      </section>
    </article>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .policy-main {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 1.5rem 5rem;
  }

  .policy-eyebrow {
    font-family: 'Jost', system-ui, sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #c9a84c;
    margin: 0 0 1.25rem;
  }

  .policy-h1 {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-weight: 500;
    font-size: clamp(2.2rem, 6vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: #f0ebe0;
    margin: 0 0 0.75rem;
  }

  .policy-updated {
    font-family: 'Jost', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #6b6760;
    margin: 0 0 3rem;
  }

  .policy-section {
    margin: 0 0 2.5rem;
    font-family: 'Jost', system-ui, sans-serif;
    font-weight: 300;
    font-size: 1rem;
    line-height: 1.75;
    color: #a39e92;
  }

  .policy-section h2 {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-weight: 500;
    font-size: 1.6rem;
    color: #f0ebe0;
    margin: 0 0 1rem;
  }

  .policy-section p {
    margin: 0 0 1em;
  }

  .policy-section ul {
    margin: 0 0 1em;
    padding-left: 1.25rem;
  }

  .policy-section li {
    margin: 0 0 0.5em;
  }

  .policy-section a {
    color: #c9a84c;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .policy-section strong {
    color: #f0ebe0;
    font-weight: 500;
  }
</style>
