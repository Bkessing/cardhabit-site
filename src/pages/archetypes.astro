---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Ornament from '../components/Ornament.astro';
import Archetypes from '../components/Archetypes.astro';
import Waitlist from '../components/Waitlist.astro';
import SiteFooter from '../components/SiteFooter.astro';

const title = 'The Four Archetypes: CardHabit Paths (Ironclad, Sage, Alchemist, Phantom)';
const description = 'CardHabit\'s four archetypes shape your deck based on the categories you play most. Ironclad rewards Physical discipline, Sage rewards Mental clarity, Alchemist rewards Nutrition balance, Phantom rewards Recovery. You earn an archetype after your first ten completed cards.';
---

<BaseLayout title={title} description={description}>
  <Nav />
  <main>
    <!-- Page hero -->
    <section style="padding:5rem 1.5rem 3rem;text-align:center;">
      <div style="max-width:780px;margin:0 auto;">
        <p style="font-family:'Jost',system-ui,sans-serif;font-size:10px;font-weight:500;letter-spacing:0.28em;text-transform:uppercase;color:#c9a84c;margin:0 0 1.25rem;">
          The paths
        </p>
        <h1 style="font-family:'Cormorant Garamond',Georgia,serif;font-weight:500;font-size:clamp(2.4rem,7vw,3.75rem);line-height:1.04;letter-spacing:-0.015em;color:#f0ebe0;margin:0 0 1.75rem;">
          The four <em style="color:#c9a84c;font-style:italic;">archetypes.</em>
        </h1>
        <p style="font-family:'Jost',system-ui,sans-serif;font-weight:300;font-size:1.05rem;line-height:1.7;color:#a39e92;max-width:620px;margin:0 auto;">
          CardHabit's archetype system isn't a personality quiz. It's an emergent classification. The first ten habit cards you complete reveal which of four paths your behavior points toward. Each archetype unlocks abilities that bend the deck toward your strengths and let you press the categories you already favor.
        </p>
      </div>
    </section>

    <Ornament />

    <Archetypes />

    <Ornament />

    <!-- Deeper detail per archetype -->
    <section style="padding:4rem 1.5rem;">
      <div style="max-width:780px;margin:0 auto;">
        <h2 style="font-family:'Cormorant Garamond',Georgia,serif;font-weight:500;font-size:clamp(1.8rem,5vw,2.5rem);line-height:1.1;color:#f0ebe0;margin:0 0 2.5rem;text-align:center;">
          What each path <em style="color:#c9a84c;font-style:italic;">rewards.</em>
        </h2>

        <div style="font-family:'Jost',system-ui,sans-serif;font-weight:300;font-size:1rem;line-height:1.75;color:#a39e92;max-width:620px;margin:0 auto;">
          <h3 style="font-family:'Cormorant Garamond',Georgia,serif;font-weight:500;font-size:1.5rem;color:#c9a84c;margin:0 0 0.5rem;">Ironclad: Physical · Discipline</h3>
          <p style="margin:0 0 2rem;">Ironclad rewards consistent physical commitments: workouts, mobility, daily movement that adds up. The path's abilities favor stacking harder Physical cards and converting their completions into resilient streak protection. <em>Strength through repetition.</em></p>

          <h3 style="font-family:'Cormorant Garamond',Georgia,serif;font-weight:500;font-size:1.5rem;color:#c9a84c;margin:0 0 0.5rem;">Sage: Mental · Clarity</h3>
          <p style="margin:0 0 2rem;">Sage rewards practices that train attention and judgment: reading, journaling, deep work, meditation. The path's abilities surface higher-rarity Mental cards in your daily draw and improve the cards you earn on completion. <em>Knowledge as power.</em></p>

          <h3 style="font-family:'Cormorant Garamond',Georgia,serif;font-weight:500;font-size:1.5rem;color:#c9a84c;margin:0 0 0.5rem;">Alchemist: Nutrition · Balance</h3>
          <p style="margin:0 0 2rem;">Alchemist rewards what you put in and what you skip: nutrition, hydration, fasting windows, ingredient discipline. The path's abilities give more flexibility on the daily draw and reward category mixing. <em>Transformation through intention.</em></p>

          <h3 style="font-family:'Cormorant Garamond',Georgia,serif;font-weight:500;font-size:1.5rem;color:#c9a84c;margin:0 0 0.5rem;">Phantom: Recovery · Silence</h3>
          <p style="margin:0;">Phantom rewards rest, sleep, and recovery practices that most habit trackers ignore. The path's abilities improve the protective vault cards you earn: streak shields, double XP, defensive plays against incoming Challenges. <em>Rest is not weakness.</em></p>
        </div>
      </div>
    </section>

    <Ornament />

    <!-- Cross-links -->
    <section style="padding:4rem 1.5rem;text-align:center;">
      <div style="max-width:680px;margin:0 auto;">
        <p style="font-family:'Jost',system-ui,sans-serif;font-size:10px;font-weight:500;letter-spacing:0.28em;text-transform:uppercase;color:#c9a84c;margin:0 0 1.5rem;">
          Keep reading
        </p>
        <p style="font-family:'Cormorant Garamond',Georgia,serif;font-style:italic;font-size:1.25rem;line-height:1.6;color:#a39e92;margin:0;">
          <a href="/how-it-works" style="color:#c9a84c;text-decoration:none;border-bottom:0.5px solid rgba(201,168,76,0.4);">How CardHabit works</a> &nbsp;·&nbsp; <a href="/faq" style="color:#c9a84c;text-decoration:none;border-bottom:0.5px solid rgba(201,168,76,0.4);">Frequently asked questions</a>
        </p>
      </div>
    </section>

    <Ornament />

    <Waitlist />
  </main>
  <SiteFooter />
</BaseLayout>
