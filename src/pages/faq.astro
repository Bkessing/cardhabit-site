---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Ornament from '../components/Ornament.astro';
import Faq from '../components/Faq.astro';
import GetTheApp from '../components/GetTheApp.astro';
import SiteFooter from '../components/SiteFooter.astro';

const title = 'CardHabit FAQ: Pricing, Mechanics, Availability';
const description = 'Frequently asked questions about CardHabit. What is it, how the daily ritual works, what friends can actually do, what archetypes are, where to get it (live now on the iOS App Store), and pricing (free tier plus CardHabit Pro with a 7-day trial at founder pricing).';
---

<BaseLayout title={title} description={description}>
  <Nav />
  <main>
    <!-- Page hero -->
    <section style="padding:5rem 1.5rem 3rem;text-align:center;">
      <div style="max-width:780px;margin:0 auto;">
        <p style="font-family:'Jost',system-ui,sans-serif;font-size:10px;font-weight:500;letter-spacing:0.28em;text-transform:uppercase;color:#c9a84c;margin:0 0 1.25rem;">
          The details
        </p>
        <h1 style="font-family:'Cormorant Garamond',Georgia,serif;font-weight:500;font-size:clamp(2.4rem,7vw,3.75rem);line-height:1.04;letter-spacing:-0.015em;color:#f0ebe0;margin:0 0 1.75rem;">
          Frequently asked <em style="color:#c9a84c;font-style:italic;">questions.</em>
        </h1>
        <p style="font-family:'Jost',system-ui,sans-serif;font-weight:300;font-size:1.05rem;line-height:1.7;color:#a39e92;max-width:620px;margin:0 auto;">
          What CardHabit is, how the daily ritual works, what friends can actually do, where to get it, what it costs. All the answers in one place.
        </p>
      </div>
    </section>

    <Ornament />

    <Faq />

    <Ornament />

    <!-- Cross-links -->
    <section style="padding:4rem 1.5rem;text-align:center;">
      <div style="max-width:680px;margin:0 auto;">
        <p style="font-family:'Jost',system-ui,sans-serif;font-size:10px;font-weight:500;letter-spacing:0.28em;text-transform:uppercase;color:#c9a84c;margin:0 0 1.5rem;">
          Keep reading
        </p>
        <p style="font-family:'Cormorant Garamond',Georgia,serif;font-style:italic;font-size:1.25rem;line-height:1.6;color:#a39e92;margin:0;">
          <a href="/how-it-works" style="color:#c9a84c;text-decoration:none;border-bottom:0.5px solid rgba(201,168,76,0.4);">How CardHabit works</a> &nbsp;·&nbsp; <a href="/archetypes" style="color:#c9a84c;text-decoration:none;border-bottom:0.5px solid rgba(201,168,76,0.4);">The four archetypes</a>
        </p>
      </div>
    </section>

    <Ornament />

    <GetTheApp />
  </main>
  <SiteFooter />
</BaseLayout>
