---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Tracked share redirect. In-app shares (single card completion, all-done
// hero moment) point here with ?src=share-<context> so the viral loop is
// measurable before the App Store handoff. See CardHabit ShareLinkBuilder.
const title = 'Opening CardHabit';
const description = 'Redirecting to CardHabit on the App Store.';

// LIVE on the App Store as of 2026-07-13 (matches /invite).
const STORE_URL = 'https://apps.apple.com/us/app/cardhabit-tcg-habit-tracker/id6768107296';
---

<BaseLayout title={title} description={description}>
  <main style="min-height:70vh;display:flex;align-items:center;justify-content:center;padding:2rem;text-align:center;">
    <div>
      <p style="font-family:'Jost',system-ui,sans-serif;font-size:10px;font-weight:500;letter-spacing:0.28em;text-transform:uppercase;color:#c9a84c;margin:0 0 1rem;">
        CardHabit
      </p>
      <p style="font-family:'Cormorant Garamond',Georgia,serif;font-style:italic;font-size:1.3rem;color:#a39e92;margin:0 0 1.75rem;">
        Taking you to the App Store&hellip;
      </p>
      <a
        href={STORE_URL}
        style="display:inline-block;background:#c9a84c;color:#0c0c0e;font-family:'Jost',system-ui,sans-serif;font-weight:500;font-size:13px;letter-spacing:0.12em;text-transform:uppercase;padding:0.9rem 2rem;border-radius:3px;"
      >
        Continue to the App Store
      </a>
    </div>
  </main>

  <script is:inline define:vars={{ STORE_URL }}>
    // Log the click with the src param preserved, then hand off to the App
    // Store. Deferred to DOMContentLoaded so window.posthog (initialized by
    // BaseLayout's script, which sits later in the DOM) is guaranteed to
    // exist before capture() is called — this inline script runs during
    // initial parse, before BaseLayout's own script tag has executed.
    function goShareRedirect() {
      var params = new URLSearchParams(window.location.search);
      var src = params.get('src') || 'unknown';
      var done = false;
      function go() {
        if (done) return;
        done = true;
        window.location.replace(STORE_URL);
      }
      if (window.posthog && typeof window.posthog.capture === 'function') {
        try { window.posthog.capture('share_link_opened', { src: src }); } catch (e) {}
        // Give the event a moment to leave the page before navigating away —
        // redirecting in the same tick cancels PostHog's in-flight request and
        // loses the click. The visible button below covers anyone impatient.
        setTimeout(go, 450);
      } else {
        go();
      }
      // Absolute safety net: never strand a visitor on /s.
      setTimeout(go, 1500);
    }
    document.addEventListener('DOMContentLoaded', goShareRedirect);
  </script>
</BaseLayout>
